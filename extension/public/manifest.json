{
	"manifest_version": 3,
	"name": "Mindapp",
	"version": "2026.06.28",
	"icons": { "1024": "mindapp-logo.png" },
	"description": "Mindapp is a tool for saving, organizing, and sharing things. Press `Alt m`, right click, or click the pinned icon to begin.",
	"permissions": ["contextMenus"],
	"action": {},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"]
		},
		{
			"matches": [
				"http://localhost:1111/*",
				"http://localhost:8888/*",
				"http://new.mindapp.cc/*",
				"https://new.mindapp.cc/*",
				"http://mindapp.cc/*",
				"https://mindapp.cc/*"
			],
			"css": ["styles.css"]
		}
	]
}
